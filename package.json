{
  "name": "freessenger",
  "version": "1.0.0",
  "description": "Simple WebSocket messenger with hash-based rooms",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server.js",
    "client": "npm run dev --prefix client",
    "build": "npm run build --prefix client"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "websocket",
    "messenger",
    "chat"
  ],
  "author": "",
  "license": "MIT"
}
